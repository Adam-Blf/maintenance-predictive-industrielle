# =============================================================================
# .gitignore · Projet Maintenance Predictive Industrielle
# Strategie · push UNIQUEMENT ce qui est livre a la prof Sarah MALAEB
# (rapport PDF, slides PPTX, code source, doc RNCP, README).
# Tout le reste est regenerable via les scripts numerotes.
# =============================================================================

# --- Notes de travail Claude Code (FACTS.md, memoire personnelle Adam) ---
.claude/

# --- Scripts de developpement (pas livres) ---
scripts/_build_*.py
scripts/_scan_*.py
scripts/_*.json
scripts/*.local.py

# --- Donnees brutes et intermediaires (lourdes, regenerables) ---
data/raw/*.csv
data/processed/*.csv
data/processed/*.parquet
!data/raw/.gitkeep
!data/processed/.gitkeep

# --- Artefacts modeles (regenerables via scripts/03_train_models.py) ---
models/*.joblib
models/*.pkl
models/*.h5
!models/.gitkeep

# --- Rapports intermediaires (figures regenerables, embed dans le PDF final) ---
reports/02/
reports/03/
reports/04/
reports/05/
reports/07/
reports/08/
reports/09/
reports/10/

# --- PDFs · on conserve le sujet officiel, le referentiel RNCP et le
#     rapport final livrable. Tous les autres PDF (build artefacts, drafts) ignores.
*.pdf
!reports/06/rapport_projet_data_science.pdf
!docs/Projet M1 DE Sujet 1 - Maintenance Prédictive Industrielle.pdf
!docs/Référentiel RNCP40875 .PDF

# --- PowerPoints · on conserve uniquement la presentation finale ---
*.pptx
!reports/11/presentation.pptx

# --- Fichiers de lock Office (Word/Excel/PowerPoint en cours d'edition) ---
~$*
*.lock

# --- Caches Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Environnements virtuels ---
.venv/
venv/
env/
ENV/

# --- Caches outils ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# --- Notebooks Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Streamlit ---
.streamlit/secrets.toml

# --- Logs ---
*.log
logs/

# --- Fichiers temporaires ---
*.tmp
*.bak
*.orig

# --- Secrets (defense en profondeur) ---
.env
.env.*
!.env.example
*secret*
*.token
*.key
*.pem
sbp_*
ghp_*
github_pat_*

# --- Sortie Black/isort/Prettier ---
.black-cache/

# --- PyInstaller (build.py · regenerable via `python build.py`) ---
# Le LANCER.exe livrable est tracke (root du repo, ~11 Mo).
# Les artefacts intermediaires sont ignores · regenerables.
*.spec
LANCER.spec
MaintenancePredictive/
# build/ et dist/ sont deja ignores plus haut dans la section caches Python

# --- CodeCarbon (cachedir + traces emissions) ---
cachedir/
emissions.csv
reports/codecarbon/

# --- Joblib disk cache ---
joblib_cache/
